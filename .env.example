# MQTT broker used by Frigate.
FRIGATE_MQTT_HOST=192.168.1.100
FRIGATE_MQTT_PORT=1883
FRIGATE_MQTT_USER=
FRIGATE_MQTT_PASSWORD=
FRIGATE_MQTT_TOPIC=frigate/reviews

# Frigate HTTP API.
# Do not use localhost here unless Frigate runs in the same container network.
FRIGATE_HOST=192.168.1.100
FRIGATE_PORT=5000
FRIGATE_EXTERNAL_URL=http://192.168.1.100:5000

# Pushover credentials.
PUSHOVER_TOKEN=
PUSHOVER_USER=
